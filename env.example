# Required auth
X_OAUTH_CONSUMER_KEY=
X_OAUTH_CONSUMER_SECRET=
X_BEARER_TOKEN=

# OAuth1 callback
X_OAUTH_CALLBACK_HOST=127.0.0.1
X_OAUTH_CALLBACK_PORT=8976
X_OAUTH_CALLBACK_PATH=/oauth/callback
X_OAUTH_CALLBACK_TIMEOUT=300

# X API settings
X_API_BASE_URL=https://api.x.com
X_API_TIMEOUT=30
X_API_DEBUG=1

# MCP server settings
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Tool filtering (optional, comma-separated)
X_API_TOOL_ALLOWLIST=

# Optional Grok test client
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# OAuth 1.0a pre-provisioned user tokens (optional, see PR #3)
# If both are set, build_oauth1_client() skips the browser flow.
X_OAUTH_ACCESS_TOKEN=
X_OAUTH_ACCESS_TOKEN_SECRET=

# OAuth 2.0 user-context auth (optional)
# CLIENT_ID / CLIENT_SECRET: from the X Developer Portal (OAuth 2.0 section).
# CLIENT_SECRET is empty for public/PKCE-only clients.
# Run `python generate_oauth2_token.py` to populate the access + refresh tokens.
# When X_OAUTH2_ACCESS_TOKEN is set, the server uses OAuth 2.0 Bearer auth
# for all requests (unblocks bookmarks, searchNews, and other endpoints
# that reject OAuth 1.0a with 403 "Unsupported Authentication").
CLIENT_ID=
CLIENT_SECRET=
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=

# Optional TLS for generate_oauth2_token.py when using a non-localhost
# callback host (e.g. a tailnet or LAN hostname so a browser on another
# machine can complete the OAuth 2.0 redirect). X requires HTTPS for
# non-localhost callback URLs. Paths are relative to the repo root.
X_OAUTH_CALLBACK_SCHEME=
TLS_CERT_FILE=
TLS_KEY_FILE=

# OAuth1 debug output (optional)
X_OAUTH_PRINT_TOKENS=
X_OAUTH_PRINT_AUTH_HEADER=
